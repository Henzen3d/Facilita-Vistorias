# ==============================
# App
# ==============================
NODE_ENV=development
APP_URL=http://localhost:3000
# Em produção: https://app.facilitavistorias.com.br

# ==============================
# Banco de dados (PostgreSQL)
# ==============================
DATABASE_URL="postgresql://vistorias:changeme@postgres:5432/vistorias?schema=public"

# ==============================
# Redis (fila BullMQ)
# ==============================
REDIS_URL="redis://redis:6379"

# ==============================
# Auth (NextAuth)
# ==============================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=changeme-gerar-com-openssl-rand-base64-32
# Usado para assinar os tokens de acesso público do relatório (locatário/locador)
PUBLIC_REPORT_JWT_SECRET=changeme-gerar-outro-secret
PUBLIC_REPORT_TOKEN_EXPIRES_IN=30d

# ==============================
# Storage — trocar entre "r2" e "minio" sem mudar código
# ==============================
STORAGE_PROVIDER=r2
STORAGE_BUCKET=app-facilita

# Cloudflare R2 (usado quando STORAGE_PROVIDER=r2)
R2_ACCOUNT_ID=f03990aa591da325a38c2bb03fdfcbdd
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://f03990aa591da325a38c2bb03fdfcbdd.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=

# MinIO (usado quando STORAGE_PROVIDER=minio — já sobe junto no docker-compose)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme

# ==============================
# IA — ordem de prioridade e chaves de cada provedor
# ==============================
# Worker assíncrono (BullMQ): rode `npm run worker` em processo separado
# (tsx worker/index.ts). Requer REDIS_URL (acima) + pelo menos GEMINI_API_KEY
# para STT/descrição (OpenAI/Anthropic opcionais como fallback).
# Depende de Redis para as filas ai-describe-item e generate-pdf.
# Sem o worker, jobs de IA/PDF ficam enfileirados e não processam.
#
# Lista separada por vírgula, na ordem em que devem ser tentados
AI_PROVIDER_PRIORITY=gemini,openai,anthropic

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FREE_TIER_MONTHLY_LIMIT=1500

OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_AUDIO_MODEL=whisper-1

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ==============================
# Cloudflare Tunnel
# ==============================
TUNNEL_TOKEN=cloudflared.exe service install eyJhIjoiZjAzOTkwYWE1OTFkYTMyNWEzOGMyYmIwM2ZkZmNiZGQiLCJ0IjoiMmY0NWY0Y2QtODdhMy00MjVjLThiNGYtODdhMDI1MmIzNTI4IiwicyI6Ik9HTmhNbU00TURFdE4ySTBOQzAwT0RZeExUZzRZMlV0TkdKaE16VXdNMk5rWmpobSJ9

# ==============================
# Notificações (contestação)
# ==============================
NOTIFY_EMAILS=equipe@facilitavistorias.com.br
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Facilita Vistorias <nao-responda@facilitavistorias.com.br>"

# WhatsApp de contato (usado nos deep links wa.me)
WHATSAPP_NUMBER=5547989108844
