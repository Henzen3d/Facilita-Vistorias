    "prisma": "^5.22.0",
    "next-auth": "^4.24.10",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8",
    "bullmq": "^5.21.2",
    "ioredis": "^5.4.1",
    "@aws-sdk/client-s3": "^3.679.0",
    "@aws-sdk/s3-request-presigner": "^3.679.0",
    "@google/generative-ai": "^0.21.0",
    "openai": "^4.68.4",
    "@anthropic-ai/sdk": "^0.29.0",
    "puppeteer": "^23.7.0",
    "qrcode": "^1.5.4",
